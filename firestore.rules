rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Family trip comments
    match /comments/{id} {
      allow read: if true;
      allow create: if request.resource.data.trip is string
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.name.size() <= 100;
      allow delete: if true;
      allow update: if false;
    }

    // Family trip expenses
    match /expenses/{id} {
      allow read: if true;
      allow create: if request.resource.data.trip is string
                    && request.resource.data.desc.size() <= 300
                    && request.resource.data.notes.size() <= 1000;
      allow delete: if true;
      allow update: if false;
    }

    // Family trip photo metadata (the image files live in Storage)
    match /photos/{id} {
      allow read: if true;
      allow create: if request.resource.data.trip is string
                    && request.resource.data.url is string;
      allow delete: if true;
      allow update: if false;
    }

    // Dashboard password hash (set once; reset by deleting the doc in console)
    match /config/{id} {
      allow read: if true;          // only a SHA-256 hash is stored, never the password
      allow create: if true;        // first person sets it
      allow update, delete: if false;
    }

    // Everything else locked
    match /{document=**} { allow read, write: if false; }
  }
}
